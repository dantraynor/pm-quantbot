# ================================
# Polymarket Trading Bot - Environment Configuration
# ================================
# SECURITY WARNING: Never commit this file with real credentials!
# Copy to .env and fill in your values

# ================================
# Wallet & Authentication
# ================================
# L1 Private Key (for deriving L2 credentials)
PRIVATE_KEY=

# Gnosis Safe Address (Signature Type 2)
GNOSIS_SAFE_ADDRESS=

# Optional: direct EOA tracking for dashboard holdings
WALLET_ADDRESS=

# Optional: one or more Polymarket proxy wallets to track in the dashboard
POLYMARKET_PROXY_WALLET_ADDRESSES=

# Optional: override/add tracked dashboard wallets as comma-separated
# label=address entries, e.g. EOA=0x...,Safe=0x...,Proxy=0x...
CHAIN_HOLDINGS_ADDRESSES=

# Optional: extra ERC-1155 token IDs to check even if they are not in Redis open positions
CHAIN_HOLDINGS_EXTRA_TOKEN_IDS=

# CLOB API Credentials (L2 derived)
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_PASSPHRASE=

# ================================
# GCP Secret Manager (Production)
# ================================
USE_SECRET_MANAGER=false
SECRET_NAME=tradingbot-credentials
GCP_PROJECT_ID=

# ================================
# Network Configuration
# ================================
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
CHAIN_ID=137

# ================================
# Polymarket Endpoints
# ================================
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
CLOB_API_URL=https://clob.polymarket.com
RELAYER_URL=https://relayer.polymarket.com

# ================================
# Redis Configuration
# ================================
REDIS_SOCKET_PATH=/var/run/redis/redis.sock

# ================================
# Production Docker Registry
# ================================
REGISTRY_PREFIX=YOUR_REGION-docker.pkg.dev/YOUR_PROJECT/tradingbot
IMAGE_TAG=latest

# ================================
# Monitoring
# ================================
GRAFANA_ADMIN_PASSWORD=

# ================================
# Dashboard (Next.js UI)
# ================================
# Optional label in the sidebar / login (default: Trading Terminal)
# NEXT_PUBLIC_APP_NAME=
# Required for production: min 16 characters. Signs the session cookie only (not sent to Polymarket).
DASHBOARD_API_SECRET=
# Local dev only: set to "true" to skip dashboard login (never use in production)
# DASHBOARD_INSECURE_DEV_BYPASS=true

# ================================
# Trading Parameters
# ================================
# Arbitrage buffer (0.005 = 0.5%)
ARBITRAGE_BUFFER=0.005

# Minimum edge in USD to trigger execution
MIN_EDGE_USD=0.50

# Maximum position size per trade
MAX_POSITION_SIZE=1000

# Maximum slippage in basis points (50 = 0.5%)
MAX_SLIPPAGE_BPS=50

# Minimum profit threshold for execution
MIN_PROFIT_THRESHOLD=0.50

# ================================
# Safety Settings
# ================================
# Kill switch check interval (ms)
KILL_SWITCH_CHECK_INTERVAL=100

# Heartbeat timeout (seconds)
HEARTBEAT_TIMEOUT_SECS=60

# Maximum reconnect attempts
MAX_RECONNECT_ATTEMPTS=10

# ================================
# Logging
# ================================
LOG_LEVEL=info
RUST_LOG=info
NODE_ENV=development

# ================================
# BTC 5-Minute Box Spread Arbitrage
# ================================
# Paper trading mode (set to false for live trading)
BTC_5M_DRY_RUN=true

# Max USDC per side per window (risk cap for liquidity-driven sweep)
BTC_5M_MAX_POSITION_USDC=5000

# Max shares per individual FOK order (large positions split into chunks)
BTC_5M_MAX_ORDER_SHARES=80

# Minimum edge in basis points to execute (150 = 1.5%)
BTC_5M_MIN_EDGE_BPS=150

# Hard ceiling on combined UP+DOWN cost (must be < 1.00)
BTC_5M_MAX_COMBINED_COST=0.985

# Order book scan interval in milliseconds
BTC_5M_SCAN_INTERVAL_MS=500

# Start scanning this many seconds into the 5-min window
BTC_5M_ENTRY_START_SEC=30

# Stop scanning this many seconds into the 5-min window
BTC_5M_ENTRY_END_SEC=250

# Max order book levels to walk (sweep stops when combined VWAP exceeds threshold)
BTC_5M_MAX_BOOK_LEVELS=50

# Maximum daily loss in USDC before auto-halt (partial fill protection)
BTC_5M_MAX_DAILY_LOSS_USDC=200

# ================================
# BTC 5-Minute Momentum Sniper
# ================================
# Paper trading mode (set to false for live trading)
BTC_5M_MOM_DRY_RUN=true

# Evaluate at T-N seconds before window close
BTC_5M_MOM_ENTRY_SECONDS_BEFORE=10

# Minimum BTC movement in basis points (5 = 0.05%)
BTC_5M_MOM_MIN_DIRECTION_BPS=5

# Contract price range to enter ($0.85-$0.95)
BTC_5M_MOM_MIN_ENTRY_PRICE=0.85
BTC_5M_MOM_MAX_ENTRY_PRICE=0.95

# Max USDC per window
BTC_5M_MOM_MAX_BET_USDC=100

# Max shares per individual FOK order
BTC_5M_MOM_MAX_ORDER_SHARES=80

# Daily loss cap (auto-halts trading)
BTC_5M_MOM_MAX_DAILY_LOSS_USDC=300

# Consecutive loss streak breaker
BTC_5M_MOM_MAX_CONSECUTIVE_LOSSES=5
BTC_5M_MOM_STREAK_PAUSE_MINUTES=30

# Binance WebSocket URL for BTC spot price
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@ticker

# ================================
# BTC 5-Minute Latency Arbitrage
# ================================
# Paper trading mode (set to false for live trading)
BTC_5M_LAT_DRY_RUN=true

# Bankroll for Kelly sizing
BTC_5M_LAT_BANKROLL=10000

# Minimum edge to trigger trade (0.08 = 8% probability advantage)
BTC_5M_LAT_MIN_EDGE=0.08

# Don't pay more than trueProb - buffer
BTC_5M_LAT_EDGE_BUFFER=0.02

# Quarter-Kelly sizing
BTC_5M_LAT_KELLY_MULTIPLIER=0.25

# Max $ per window per side
BTC_5M_LAT_MAX_POSITION_PER_WINDOW=500

# Rolling volatility lookback (seconds)
BTC_5M_LAT_VOL_LOOKBACK_SEC=300

# Tick aggregation interval (ms)
BTC_5M_LAT_TICK_AGGREGATION_MS=100

# Time boundaries within window (seconds)
BTC_5M_LAT_MIN_TIME_REMAINING=10
BTC_5M_LAT_MAX_TIME_REMAINING=290

# Max shares per FOK order chunk
BTC_5M_LAT_MAX_ORDER_SHARES=80

# Session drawdown limit (cumulative, not daily)
BTC_5M_LAT_MAX_SESSION_DRAWDOWN=2000

# Daily loss limit
BTC_5M_LAT_MAX_DAILY_LOSS_USDC=1000

# Reduce sizing when BTC moves > $500 in 5 min
BTC_5M_LAT_TREND_THRESHOLD=500

# Halt if Chainlink vs exchange diverges > $100 for 30s
BTC_5M_LAT_ORACLE_DIVERGENCE_LIMIT=100
BTC_5M_LAT_ORACLE_DIVERGENCE_DURATION_MS=30000

# Skip if book depth < $50 per level
BTC_5M_LAT_MIN_BOOK_DEPTH_USDC=50

# Consecutive loss streak
BTC_5M_LAT_MAX_CONSECUTIVE_LOSSES=5
BTC_5M_LAT_STREAK_PAUSE_MINUTES=30

# Binance individual trade stream (not ticker)
BTC_5M_LAT_BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@trade

# Coinbase WebSocket
BTC_5M_LAT_COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com

# Chainlink oracle polling
BTC_5M_LAT_CHAINLINK_POLL_MS=1000
BTC_5M_LAT_CHAINLINK_RPC_URL=https://polygon-bor-rpc.publicnode.com
BTC_5M_LAT_CHAINLINK_AGGREGATOR=0xc907E116054Ad103354f2D350FD2514433D57F6f

# ================================
# Alpha Executor
# ================================
ALPHA_DRY_RUN=true
ALPHA_MAX_ORDER_SHARES=80
TAKER_FEE_BPS=0

# ================================
# Crypto Signals
# ================================
CRYPTO_BINANCE_SYMBOLS=btcusdt,ethusdt,solusdt
CRYPTO_MIN_DIRECTION_BPS=5
CRYPTO_MIN_ENTRY_PRICE=0.10
CRYPTO_MAX_ENTRY_PRICE=0.95
CRYPTO_MIN_EDGE_BPS=500
CRYPTO_SCAN_INTERVAL_MS=500
CRYPTO_ENTRY_START_SEC=30
CRYPTO_ENTRY_END_SEC=250

# ================================
# Sports Signals
# ================================
SPORTS_MIN_ENTRY_PRICE=0.10
SPORTS_MAX_ENTRY_PRICE=0.95
SPORTS_MIN_EDGE_BPS=500
SPORTS_SCAN_INTERVAL_MS=10000
SPORTS_SCORE_POLLING_MS=5000
ESPN_API_URL=https://site.api.espn.com
